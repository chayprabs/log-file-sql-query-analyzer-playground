/*
  Cache-Control: no-store
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' blob:; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'none'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 0
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

/sql-wasm-browser.wasm
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  Content-Type: application/wasm

/sql-wasm.wasm
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
  Content-Type: application/wasm

/sample.log
  Cache-Control: public, max-age=3600
